# RangeDOPE — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git — it's in .gitignore already.

# ─── RevenueCat ───────────────────────────────────────────────────────────────
# Get these from: https://app.revenuecat.com → Project → API Keys
# iOS key starts with "appl_", Android key starts with "goog_"
EXPO_PUBLIC_RC_APPLE_KEY=appl_YOUR_KEY_HERE
EXPO_PUBLIC_RC_GOOGLE_KEY=goog_YOUR_KEY_HERE

# Set to "true" only when ready to charge real money (App Store release).
# Keep "false" during TestFlight beta — all features unlocked for testers.
EXPO_PUBLIC_PAYWALL_ENABLED=false

# ─── Open-Meteo (Wind Risk) ───────────────────────────────────────────────────
# Open-Meteo is free with no API key for standard use.
# If you exceed the free tier, sign up at: https://open-meteo.com/en/pricing
# Leave blank to use the anonymous free tier.
EXPO_PUBLIC_OPEN_METEO_API_KEY=

# ─── MapLibre / Tile Sources ──────────────────────────────────────────────────
# All current tile sources (USGS, ESRI) are free with no key required.
# If you add a MapTiler or Maptiler account for premium vector tiles:
# EXPO_PUBLIC_MAPTILER_KEY=YOUR_KEY_HERE

# ─── EAS / Expo ───────────────────────────────────────────────────────────────
# Your Apple Developer account email — used by `eas submit` to authenticate.
# Never commit .env to git. Set this here, not in eas.json.
EXPO_APPLE_ID=YOUR_APPLE_ID_EMAIL@example.com

# Privacy policy URL — host docs/privacy-policy.html on GitHub Pages.
# Repo Settings → Pages → Branch: main, Folder: /docs
EXPO_PUBLIC_PRIVACY_URL=https://meastt.github.io/LongRangeShooterSim/privacy-policy.html

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Override the free-tier profile limit (default: 1 free, unlimited Pro)
# Set to 999 during TestFlight so testers can create unlimited profiles.
# Set to 1 for production App Store release.
EXPO_PUBLIC_FREE_PROFILE_LIMIT=999

# --- Sentry Crash Reporting ---
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_DSN@sentry.io/PROJECT_ID
