---
import Base from '../layouts/Base.astro';
---
<Base title="RangeDOPE — Long-Range Ballistic Solver & Hunt Planning for iOS">

<style>
  /* ── Nav ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px clamp(20px, 5vw, 60px);
    background: rgba(8,8,8,0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }
  .nav-brand { display: flex; align-items: center; gap: 10px; }
  .nav-logo { width: 32px; height: 32px; border-radius: 8px; }
  .nav-name {
    font-family: var(--font-mono); font-size: 14px; font-weight: 700;
    letter-spacing: 2px; color: var(--label);
  }
  .nav-name span { color: var(--primary); }
  .nav-link {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 2px;
    color: var(--dim); border: 1px solid var(--border); border-radius: var(--radius-sm);
    padding: 8px 16px; transition: all 0.2s;
  }
  .nav-link:hover { color: var(--primary); border-color: var(--primary); opacity: 1; }

  /* ── Hero ── */
  .hero {
    min-height: 100dvh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center;
    padding: 120px clamp(20px, 5vw, 60px) 80px;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; top: -200px; left: 50%; transform: translateX(-50%);
    width: 800px; height: 800px; border-radius: 50%;
    background: radial-gradient(circle, rgba(255,48,0,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 2px;
    color: var(--primary); background: var(--primary-g);
    border: 1px solid rgba(255,48,0,0.25); border-radius: 999px;
    padding: 6px 16px; margin-bottom: 32px;
  }
  .hero-badge::before { content: '●'; font-size: 7px; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

  .hero-logo {
    width: clamp(80px, 12vw, 120px); height: clamp(80px, 12vw, 120px);
    border-radius: clamp(20px, 3vw, 28px);
    margin: 0 auto 32px;
    box-shadow: 0 0 60px rgba(255,48,0,0.2), 0 20px 60px rgba(0,0,0,0.6);
  }
  h1 {
    font-size: clamp(48px, 8vw, 96px); font-weight: 700; line-height: 1.0;
    letter-spacing: -2px; color: var(--white); margin-bottom: 8px;
  }
  h1 span { color: var(--primary); }
  .hero-sub {
    font-family: var(--font-mono); font-size: clamp(11px, 1.5vw, 13px);
    letter-spacing: 3px; color: var(--dim); margin-bottom: 24px;
    text-transform: uppercase;
  }
  .hero-desc {
    font-size: clamp(16px, 2vw, 20px); color: #aaa; max-width: 560px;
    margin: 0 auto 48px; font-weight: 300;
  }
  .hero-cta { display: flex; gap: 16px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--primary); color: var(--white);
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 2px;
    padding: 16px 32px; border-radius: var(--radius-sm);
    transition: all 0.2s; text-transform: uppercase;
  }
  .btn-primary:hover { background: var(--primary-d); opacity: 1; transform: translateY(-1px); }
  .btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--dim); font-family: var(--font-mono); font-size: 11px; letter-spacing: 1.5px;
    border: 1px solid var(--border2); padding: 16px 28px; border-radius: var(--radius-sm);
    transition: all 0.2s; text-transform: uppercase;
  }
  .btn-ghost:hover { color: var(--label); border-color: var(--dim); opacity: 1; }

  /* ── Stats bar ── */
  .stats {
    display: flex; gap: 0; border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .stat {
    flex: 1; padding: 28px 24px; text-align: center;
    border-right: 1px solid var(--border);
  }
  .stat:last-child { border-right: none; }
  .stat-val {
    font-family: var(--font-mono); font-size: clamp(22px, 3vw, 32px);
    font-weight: 700; color: var(--primary); display: block;
  }
  .stat-label {
    font-family: var(--font-mono); font-size: 9px; letter-spacing: 2px;
    color: var(--dim); text-transform: uppercase; margin-top: 4px;
  }

  /* ── Features ── */
  .features {
    max-width: var(--max-w); margin: 0 auto;
    padding: 100px clamp(20px, 5vw, 60px);
  }
  .section-label {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 3px;
    color: var(--primary); text-transform: uppercase; margin-bottom: 16px;
  }
  .section-title {
    font-size: clamp(28px, 4vw, 48px); font-weight: 700;
    letter-spacing: -1px; color: var(--white); margin-bottom: 60px;
    max-width: 500px;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1px; background: var(--border);
    border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden;
  }
  .feature-card {
    background: var(--surface); padding: 36px 32px;
    transition: background 0.2s;
  }
  .feature-card:hover { background: var(--surface2); }
  .feature-icon {
    font-size: 32px; margin-bottom: 20px; display: block;
    filter: drop-shadow(0 0 12px rgba(255,48,0,0.3));
  }
  .feature-title {
    font-size: 18px; font-weight: 600; color: var(--white);
    margin-bottom: 10px; letter-spacing: -0.3px;
  }
  .feature-desc { font-size: 14px; color: var(--dim); line-height: 1.7; }
  .feature-tag {
    display: inline-block; margin-top: 16px;
    font-family: var(--font-mono); font-size: 9px; letter-spacing: 1.5px;
    color: var(--primary); background: var(--primary-g);
    border: 1px solid rgba(255,48,0,0.2); border-radius: 4px; padding: 3px 8px;
  }

  /* ── Map strip ── */
  .map-strip {
    background: var(--surface);
    border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    padding: 80px clamp(20px, 5vw, 60px);
    display: flex; align-items: center; justify-content: center;
    gap: 60px; flex-wrap: wrap;
  }
  .map-strip-text { max-width: 480px; }
  .map-strip-text h2 {
    font-size: clamp(24px, 3.5vw, 40px); font-weight: 700;
    letter-spacing: -0.8px; color: var(--white); margin-bottom: 16px;
  }
  .map-strip-text p { font-size: 15px; color: var(--dim); line-height: 1.8; }
  .map-layers {
    display: flex; flex-direction: column; gap: 10px; min-width: 200px;
  }
  .layer-pill {
    display: flex; align-items: center; gap: 12px;
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: 12px 16px;
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 1.5px;
    color: var(--label);
  }
  .layer-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

  /* ── CTA ── */
  .cta-section {
    max-width: var(--max-w); margin: 0 auto;
    padding: 100px clamp(20px, 5vw, 60px);
    text-align: center;
  }
  .cta-box {
    background: linear-gradient(135deg, var(--surface) 0%, rgba(255,48,0,0.06) 100%);
    border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: clamp(40px, 6vw, 80px) clamp(24px, 6vw, 80px);
    position: relative; overflow: hidden;
  }
  .cta-box::before {
    content: '';
    position: absolute; top: -100px; right: -100px;
    width: 400px; height: 400px; border-radius: 50%;
    background: radial-gradient(circle, rgba(255,48,0,0.06) 0%, transparent 70%);
  }
  .cta-box h2 {
    font-size: clamp(28px, 4vw, 52px); font-weight: 700;
    letter-spacing: -1px; color: var(--white); margin-bottom: 16px;
  }
  .cta-box h2 span { color: var(--primary); }
  .cta-box p { font-size: 16px; color: var(--dim); margin-bottom: 40px; }

  /* ── Footer ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 40px clamp(20px, 5vw, 60px);
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap;
    gap: 20px;
    max-width: 100%;
  }
  .footer-brand { display: flex; align-items: center; gap: 10px; }
  .footer-logo { width: 28px; height: 28px; border-radius: 6px; }
  .footer-name {
    font-family: var(--font-mono); font-size: 12px; letter-spacing: 2px; color: var(--dim);
  }
  .footer-links { display: flex; gap: 24px; }
  .footer-link {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 1.5px;
    color: var(--dim); text-transform: uppercase;
  }
  .footer-link:hover { color: var(--primary); opacity: 1; }
  .footer-copy {
    font-family: var(--font-mono); font-size: 10px; color: var(--dim2);
    letter-spacing: 1px;
  }

  @media (max-width: 600px) {
    .stats { flex-direction: column; }
    .stat { border-right: none; border-bottom: 1px solid var(--border); }
    .stat:last-child { border-bottom: none; }
    footer { flex-direction: column; text-align: center; }
    .footer-links { justify-content: center; }
  }
</style>

<!-- Nav -->
<nav>
  <a href="/" class="nav-brand" style="opacity:1">
    <img src="/logo.png" alt="RangeDOPE" class="nav-logo" />
    <span class="nav-name">Range<span>DOPE</span></span>
  </a>
  <a
    href="https://apps.apple.com/app/id6765543307"
    class="nav-link"
    target="_blank" rel="noopener"
  >
    APP STORE ↗
  </a>
</nav>

<!-- Hero -->
<section class="hero">
  <div class="hero-badge">NOW IN BETA</div>
  <img src="/logo.png" alt="RangeDOPE app icon" class="hero-logo" />
  <p class="hero-sub">Long-Range Ballistic Solver</p>
  <h1>Range<span>DOPE</span></h1>
  <p class="hero-desc">
    First-principles ballistic solutions, tactical topographic mapping,
    and GPS-based hunt planning — all offline, all on your iPhone.
  </p>
  <div class="hero-cta">
    <a
      href="https://apps.apple.com/app/id6765543307"
      class="btn-primary"
      target="_blank" rel="noopener"
    >
      ⬇ Download on App Store
    </a>
    <a href="#features" class="btn-ghost">See Features ↓</a>
  </div>
</section>

<!-- Stats -->
<div class="stats">
  <div class="stat">
    <span class="stat-val">G1/G7</span>
    <span class="stat-label">Drag Models</span>
  </div>
  <div class="stat">
    <span class="stat-val">5</span>
    <span class="stat-label">Map Layers</span>
  </div>
  <div class="stat">
    <span class="stat-val">100%</span>
    <span class="stat-label">Offline</span>
  </div>
  <div class="stat">
    <span class="stat-val">0</span>
    <span class="stat-label">Subscriptions to Use Core</span>
  </div>
</div>

<!-- Features -->
<section class="features" id="features">
  <p class="section-label">What it does</p>
  <h2 class="section-title">Everything in the field. Nothing you don't need.</h2>

  <div class="feature-grid">
    <div class="feature-card">
      <span class="feature-icon">🎯</span>
      <h3 class="feature-title">Precision Ballistic Solver</h3>
      <p class="feature-desc">
        Full G1/G7 drag models with spin drift, Coriolis effect, atmospheric density
        altitude, and incline correction. Real physics — not a lookup table.
      </p>
      <span class="feature-tag">FIRST PRINCIPLES</span>
    </div>
    <div class="feature-card">
      <span class="feature-icon">🗺️</span>
      <h3 class="feature-title">Tactical Map Layers</h3>
      <p class="feature-desc">
        USGS TOPO, 3DEP LiDAR relief, 3D composite satellite, and BLM land ownership
        overlay. Know exactly what's public and what's private before you walk in.
      </p>
      <span class="feature-tag">BLM OWNERSHIP</span>
    </div>
    <div class="feature-card">
      <span class="feature-icon">📍</span>
      <h3 class="feature-title">Hunt Waypoints</h3>
      <p class="feature-desc">
        Drop GPS-precise sightings, stand locations, glassing points, water sources,
        and migration corridors. Long-press the map — it's that fast.
      </p>
      <span class="feature-tag">8 WAYPOINT TYPES</span>
    </div>
    <div class="feature-card">
      <span class="feature-icon">🔭</span>
      <h3 class="feature-title">DOPE Cards & Truing</h3>
      <p class="feature-desc">
        Generate printable holdover tables for any load. True your data against
        real observed impacts with DSF, MV, and Tall Target wizards.
      </p>
      <span class="feature-tag">TRUING WIZARDS</span>
    </div>
    <div class="feature-card">
      <span class="feature-icon">💨</span>
      <h3 class="feature-title">Wind Risk Advisor</h3>
      <p class="feature-desc">
        Live wind data from Open-Meteo layered against your shot geometry. Know
        when conditions exceed your hold capability before you shoot.
      </p>
      <span class="feature-tag">LIVE WEATHER</span>
    </div>
    <div class="feature-card">
      <span class="feature-icon">☀️</span>
      <h3 class="feature-title">Sun & Glass Advisor</h3>
      <p class="feature-desc">
        Know when the sun will be behind you, in your scope, or lighting up your
        target. Plan your glassing windows and shot windows by time of day.
      </p>
      <span class="feature-tag">SOLAR PLANNING</span>
    </div>
  </div>
</section>

<!-- Map Strip -->
<div class="map-strip">
  <div class="map-strip-text">
    <p class="section-label">Land Ownership</p>
    <h2>Know where you can hunt before you hike in.</h2>
    <p>
      Toggle the BLM Surface Management Agency overlay on any map style — the same
      federal data layer used by onX Hunt, rendered free directly from government
      tile servers. No subscription required.
    </p>
  </div>
  <div class="map-layers">
    <div class="layer-pill">
      <div class="layer-dot" style="background:#f5c842"></div>
      BLM Public Land
    </div>
    <div class="layer-pill">
      <div class="layer-dot" style="background:#4a8c4a"></div>
      USFS National Forest
    </div>
    <div class="layer-pill">
      <div class="layer-dot" style="background:#2e6e2e"></div>
      National Park / NPS
    </div>
    <div class="layer-pill">
      <div class="layer-dot" style="background:#8a6a2e"></div>
      State Land
    </div>
    <div class="layer-pill">
      <div class="layer-dot" style="background:#444444"></div>
      Private Land
    </div>
  </div>
</div>

<!-- CTA -->
<section class="cta-section">
  <div class="cta-box">
    <p class="section-label">Available on iOS</p>
    <h2>Built for the <span>long shot.</span></h2>
    <p>Free to download. Core ballistic solver always free. Pro features unlock offline maps and advanced tools.</p>
    <div class="hero-cta">
      <a
        href="https://apps.apple.com/app/id6765543307"
        class="btn-primary"
        target="_blank" rel="noopener"
      >
        ⬇ Download on App Store
      </a>
    </div>
  </div>
</section>

<!-- Footer -->
<footer>
  <div class="footer-brand">
    <img src="/logo.png" alt="RangeDOPE" class="footer-logo" />
    <span class="footer-name">RANGEDOPE</span>
  </div>
  <div class="footer-links">
    <a href="/privacy" class="footer-link">Privacy Policy</a>
    <a href="mailto:support@getrangedope.com" class="footer-link">Support</a>
  </div>
  <span class="footer-copy">© {new Date().getFullYear()} RangeDOPE. All rights reserved.</span>
</footer>

</Base>
