---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Long-range ballistic solver and tactical hunt planning for iOS. Precision firing solutions, topographic mapping, and GPS-based scouting tools.',
  ogImage = '/logo.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, 'https://getrangedope.com').href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#FF3000" />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/logo.png" />

  <title>{title}</title>

  <!-- Google Fonts: Space Grotesk for headings, Space Mono for UI labels -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
    rel="stylesheet"
  />

  <style is:global>
    :root {
      --bg:        #080808;
      --surface:   #101010;
      --surface2:  #161616;
      --border:    #1e1e1e;
      --border2:   #2a2a2a;
      --primary:   #FF3000;
      --primary-d: #cc2600;
      --primary-g: rgba(255,48,0,0.12);
      --label:     #F0F0F0;
      --dim:       #888888;
      --dim2:      #555555;
      --white:     #ffffff;

      --font-sans: 'Space Grotesk', system-ui, -apple-system, sans-serif;
      --font-mono: 'Space Mono', 'SF Mono', monospace;

      --radius-sm: 6px;
      --radius-md: 12px;
      --radius-lg: 20px;

      --max-w: 1100px;
      --gap: clamp(16px, 4vw, 48px);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
    }

    body {
      background: var(--bg);
      color: var(--label);
      font-family: var(--font-sans);
      line-height: 1.6;
      min-height: 100dvh;
    }

    img { max-width: 100%; display: block; }

    a {
      color: var(--primary);
      text-decoration: none;
      transition: opacity 0.15s;
    }
    a:hover { opacity: 0.8; }

    /* Noise texture overlay for depth */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
