# ─── Build outputs (gitignored — EAS builds from source) ──────────────────────
dist/
build/
out/
.next/
*.tsbuildinfo
.turbo/
coverage/

# ─── ENV & SECRETS — never commit these ───────────────────────────────────────
.env
.env.*
!.env.example      # safe to commit — contains only placeholders

# Apple / iOS credentials
*.p8               # Apple Push Notification key
*.p12              # Distribution certificate
*.mobileprovision  # Provisioning profile
*.certSigningRequest

# Android credentials
*.keystore
*.jks

# Firebase — if ever added
google-services.json
GoogleService-Info.plist

# ─── Native build artifacts ───────────────────────────────────────────────────
**/ios/Pods/
**/ios/build/
**/android/.gradle/
**/android/app/build/
**/android/build/
*.orig.*
.kotlin/
*.aar

# ─── AI / Tool data ───────────────────────────────────────────────────────────
.gemini/           # Antigravity app data — local only, not part of codebase

